{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bubblenews.today/schemas/daily-report-v1.schema.json",
  "$comment": "Version 1 is frozen after the first production JSON is published. Breaking changes require a new schema version.",
  "title": "Bubble's Brain daily report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "identity_version",
    "dedupe_version",
    "date",
    "timezone",
    "generated_at",
    "overview",
    "producer",
    "batches",
    "items"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "identity_version": { "const": 1 },
    "dedupe_version": { "const": 1 },
    "date": { "$ref": "#/$defs/date" },
    "timezone": { "const": "Asia/Shanghai" },
    "generated_at": { "type": "string", "format": "date-time" },
    "overview": { "$ref": "#/$defs/overview" },
    "producer": { "$ref": "#/$defs/producer" },
    "batches": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "$ref": "#/$defs/batch" }
    },
    "items": {
      "type": "array",
      "maxItems": 1000,
      "items": { "$ref": "#/$defs/item" }
    }
  },
  "$defs": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "batchId": {
      "type": "string",
      "enum": ["morning", "afternoon", "night", "lateNight"]
    },
    "overview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "kind", "provenance"],
      "properties": {
        "text": { "type": "string", "minLength": 1, "maxLength": 5000 },
        "kind": { "type": "string", "enum": ["pending", "generated", "fallback"] },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method", "model", "prompt_version"],
          "properties": {
            "method": { "type": "string", "enum": ["template", "ai", "legacy"] },
            "model": { "type": ["string", "null"], "maxLength": 200 },
            "prompt_version": { "type": ["string", "null"], "maxLength": 100 }
          },
          "allOf": [
            {
              "if": { "properties": { "method": { "const": "ai" } } },
              "then": {
                "properties": {
                  "model": { "type": "string", "minLength": 1, "maxLength": 200 },
                  "prompt_version": { "type": "string", "minLength": 1, "maxLength": 100 }
                }
              }
            }
          ]
        }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "commit_sha", "dedupe_lookback_days"],
      "properties": {
        "name": { "const": "bubble-brain-worker" },
        "version": { "type": "string", "minLength": 1, "maxLength": 100 },
        "commit_sha": {
          "anyOf": [
            { "type": "string", "pattern": "^[a-f0-9]{40}$" },
            { "type": "null" }
          ]
        },
        "dedupe_lookback_days": { "const": 7 }
      }
    },
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "status", "generated_at", "item_ids"],
      "properties": {
        "id": { "$ref": "#/$defs/batchId" },
        "label": { "type": "string", "minLength": 1, "maxLength": 100 },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "generated_at": { "type": ["string", "null"], "format": "date-time" },
        "item_ids": {
          "type": "array",
          "maxItems": 1000,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/itemId" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "completed" } } },
          "then": { "properties": { "generated_at": { "type": "string", "format": "date-time" } } }
        },
        {
          "if": { "properties": { "status": { "const": "pending" } } },
          "then": {
            "properties": {
              "generated_at": { "type": "null" },
              "item_ids": { "type": "array", "maxItems": 0 }
            }
          }
        }
      ]
    },
    "itemId": {
      "type": "string",
      "pattern": "^n_[a-f0-9]{64}$"
    },
    "eventId": {
      "type": "string",
      "pattern": "^e_[a-f0-9]{64}$"
    },
    "claimId": {
      "type": "string",
      "pattern": "^c_[a-f0-9]{64}$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "id", "homepage"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "id": { "type": ["string", "null"], "maxLength": 512 },
        "homepage": { "type": ["string", "null"], "format": "uri", "maxLength": 8192 }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "event_id",
        "identity_version",
        "identity_strategy",
        "identity_claims",
        "source_type",
        "content_type",
        "source_id",
        "title",
        "url",
        "canonical_url",
        "source",
        "published_at",
        "published_date",
        "ingested_at",
        "time_precision",
        "batch",
        "summary",
        "category",
        "topics",
        "featured",
        "score",
        "reason",
        "related_source_ids"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/itemId" },
        "event_id": { "$ref": "#/$defs/eventId" },
        "identity_version": { "const": 1 },
        "identity_strategy": {
          "type": "string",
          "enum": ["canonical_url", "source_id", "fallback"]
        },
        "identity_claims": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/claimId" }
        },
        "source_type": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"
        },
        "content_type": {
          "type": "string",
          "enum": ["news", "project", "paper", "socialMedia"]
        },
        "source_id": { "type": ["string", "null"], "maxLength": 512 },
        "title": { "type": "string", "minLength": 1, "maxLength": 500 },
        "url": { "type": ["string", "null"], "format": "uri", "maxLength": 8192 },
        "canonical_url": { "type": ["string", "null"], "format": "uri", "maxLength": 8192 },
        "source": { "$ref": "#/$defs/source" },
        "published_at": { "type": ["string", "null"], "format": "date-time" },
        "published_date": {
          "anyOf": [
            { "$ref": "#/$defs/date" },
            { "type": "null" }
          ]
        },
        "ingested_at": { "type": "string", "format": "date-time" },
        "time_precision": {
          "type": "string",
          "enum": ["exact", "date_only", "inferred"]
        },
        "batch": { "$ref": "#/$defs/batchId" },
        "summary": { "type": "string", "maxLength": 5000 },
        "category": {
          "type": "string",
          "enum": [
            "models",
            "agents",
            "research",
            "products",
            "business",
            "policy",
            "open_source",
            "other"
          ]
        },
        "topics": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        },
        "featured": { "type": "boolean" },
        "score": { "type": ["number", "null"], "minimum": 0, "maximum": 10 },
        "reason": { "type": ["string", "null"], "maxLength": 1000 },
        "related_source_ids": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/itemId" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "time_precision": { "const": "exact" } } },
          "then": {
            "properties": {
              "published_at": { "type": "string", "format": "date-time" },
              "published_date": { "$ref": "#/$defs/date" }
            }
          }
        },
        {
          "if": { "properties": { "time_precision": { "const": "date_only" } } },
          "then": {
            "properties": {
              "published_at": { "type": "null" },
              "published_date": { "$ref": "#/$defs/date" }
            }
          }
        },
        {
          "if": { "properties": { "time_precision": { "const": "inferred" } } },
          "then": {
            "properties": {
              "published_at": { "type": "null" },
              "published_date": {
                "anyOf": [
                  { "$ref": "#/$defs/date" },
                  { "type": "null" }
                ]
              }
            }
          }
        }
      ]
    }
  }
}
