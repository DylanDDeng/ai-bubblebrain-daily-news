# Copy to .dev.vars for local development. Never commit .dev.vars.
ADMIN_API_TOKEN=replace-with-a-long-random-token
LOGIN_USERNAME_SECRET=replace-with-admin-username
LOGIN_PASSWORD_SECRET=replace-with-a-long-random-password
GITHUB_TOKEN=replace-with-a-fine-grained-token
OPENAI_API_KEY=replace-with-provider-key
GEMINI_API_KEY=replace-with-provider-key
FOLO_COOKIE=replace-with-folo-cookie-if-needed
