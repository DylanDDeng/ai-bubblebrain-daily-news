---
import { getCollection } from 'astro:content';

import {
	dailyDateFromKey,
	dailyPermalink,
	filterDailyEntries,
	formatDailyWeekday,
	parseDailyEntryId,
} from '../lib/daily';
import { taxonomyLabel, topicsById } from '../lib/knowledge';
import {
	cleanTimelineSummary,
	displayContentType,
	formatDailyTime,
	formatTimelineTime,
	homepageFeedItems,
	isDatabaseOwnedDailyDate,
	loadStructuredDailyReport,
	timelineDisplayText,
	timelineSourceDisplay,
	type DailyContentType,
} from '../lib/structuredDaily';
import '../styles/quiet-index.css';

interface Props {
	locale: 'zh-CN' | 'en';
}

const { locale } = Astro.props;
const isEnglish = locale === 'en';
const dailyEntries = await getCollection('daily');
const entries = filterDailyEntries(dailyEntries, locale);
const latest = entries[0];
const latestIdentity = latest ? parseDailyEntryId(latest.id) : null;
const report = latestIdentity ? await loadStructuredDailyReport(latestIdentity.dateKey) : null;
const latestHref = latest ? dailyPermalink(latest.id) : isEnglish ? '/en/daily/' : '/daily/';
const archiveHref = isEnglish ? '/en/daily/' : '/daily/';

const typeLabels: Record<DailyContentType, string> = isEnglish
	? { news: 'News', project: 'Project', paper: 'Paper', socialMedia: 'Social' }
	: { news: '资讯', project: '项目', paper: '论文', socialMedia: '社交' };
const categoryLabels: Record<string, string> = isEnglish
	? {
			models: 'Models',
			research: 'Research',
			open_source: 'Open source',
			agents: 'Agents',
			products: 'Products',
			business: 'Business',
			policy: 'Policy',
			other: 'Other',
		}
	: {
			models: '大模型',
			research: '研究论文',
			open_source: '开源项目',
			agents: '智能体',
			products: '产品',
			business: '商业',
			policy: '政策',
			other: '其他动态',
		};

const latestDate = latestIdentity ? dailyDateFromKey(latestIdentity.dateKey) : null;
const monthDay = latestDate
	? new Intl.DateTimeFormat(locale, {
			month: 'long',
			day: 'numeric',
			timeZone: 'Asia/Shanghai',
		}).format(latestDate)
	: '—';
const weekdayLong = latestDate ? formatDailyWeekday(latestDate, locale) : '';

const completedBatches = (report?.batches ?? []).filter(
	(batch) => batch.status === 'completed' && batch.generated_at,
);
const lastCompletedAt = completedBatches
	.map((batch) => batch.generated_at!)
	.sort()
	.at(-1);
const liveLabel =
	lastCompletedAt || report?.generated_at
		? formatDailyTime(lastCompletedAt ?? report!.generated_at, locale)
		: null;

const items = report?.items ?? [];
const lead = items.find((item) => item.featured) ?? items[0] ?? null;
const leadDisplayText = lead ? timelineDisplayText(lead) : null;
const leadSource = lead ? timelineSourceDisplay(lead) : null;
const feedItems = homepageFeedItems(items, report?.batches ?? []);

const categoryCounts = new Map<string, number>();
const topicCounts = new Map<string, number>();
for (const item of items) {
	categoryCounts.set(item.category, (categoryCounts.get(item.category) ?? 0) + 1);
	for (const topicId of item.topic_ids) {
		topicCounts.set(topicId, (topicCounts.get(topicId) ?? 0) + 1);
	}
}
const categoryRows = [...categoryCounts.entries()].sort((a, b) => b[1] - a[1]);
const hotTopics = [...topicCounts.entries()]
	.sort((a, b) => b[1] - a[1])
	.map(([id]) => topicsById.get(id))
	.filter((topic) => topic !== undefined)
	.slice(0, 8);

const previousDays = (
	await Promise.all(
		entries.slice(1, 4).map(async (entry) => {
			const identity = parseDailyEntryId(entry.id);
			const href = dailyPermalink(entry.id);
			if (!identity || !href) return null;
			const dayReport = isDatabaseOwnedDailyDate(identity.dateKey)
				? await loadStructuredDailyReport(identity.dateKey)
				: null;
			return {
				href,
				count: dayReport?.items.length ?? null,
				dateKey: identity.dateKey,
				date: dailyDateFromKey(identity.dateKey),
			};
		}),
	)
).filter((day) => day !== null);
---

<section class="quiet-home">
	{
		report ? (
			<>
				<header class="today-header">
					<div class="date-block">
						<h1>
							{monthDay}
							<span class="weekday">
								{weekdayLong}
								{isEnglish ? ' · Today' : ' · 今日'}
							</span>
						</h1>
					</div>
					{liveLabel && (
						<span class="live-pill">
							<span class="pulse" />
							{isEnglish ? `Updated to ${liveLabel}` : `已更新至 ${liveLabel}`}
						</span>
					)}
				</header>

				{report.batches.length > 0 && (
					<div class="schedule">
						{report.batches.map((batch) => (
							<div class={`slot ${batch.status === 'completed' ? 'done' : 'waiting'}`}>
								<span class="t">{cleanTimelineSummary(batch.label)}</span>
								<span class="s">
									{batch.status === 'completed'
										? isEnglish
											? `${batch.item_ids.length} items`
											: `${batch.item_ids.length} 条`
										: isEnglish
											? 'Scheduled'
											: '待发布'}
								</span>
							</div>
						))}
					</div>
				)}

				<div class="home-grid">
					<div>
						{lead && (
							<a
								class="lead-story"
								href={lead.canonical_url ?? latestHref}
								{...(lead.canonical_url ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
							>
								<p class="tag">{isEnglish ? 'TOP STORY' : '今日头条 · TOP STORY'}</p>
								<h2>{leadDisplayText?.title || lead.title}</h2>
								{leadDisplayText?.summary && <p>{leadDisplayText.summary}</p>}
								<p class="src">
									<span class:list={['source-label', { 'src-x': leadSource?.isX }]}>
										{leadSource?.isX && (
											<span class="x-logo" aria-label="X">
												<i class="ph ph-x-logo" aria-hidden="true" />
											</span>
										)}
										<span>{leadSource?.name}</span>
									</span>
									<span aria-hidden="true">·</span>
									<span>{formatTimelineTime(lead, locale, report.date)}</span>
								</p>
							</a>
						)}

						<div class="stream-heading">
							<h2>{isEnglish ? "Today's stream" : '今日流'}</h2>
							<span class="h-line" />
							<span class="h-meta">
								{isEnglish ? `${items.length} items` : `${items.length} 条`}
							</span>
						</div>

						{feedItems.map((item) => {
							const displayText = timelineDisplayText(item);
							const source = timelineSourceDisplay(item);
							const title = displayText.title || (isEnglish ? 'Open original source' : '查看原文');
							const summary = displayText.summary;
							return (
								<article class="feed-item">
									<span class="time">{formatTimelineTime(item, locale, report.date)}</span>
									<div>
										<div class="meta">
											<span class:list={['src', { 'src-x': source.isX }]}>
												{source.isX && (
													<span class="x-logo" aria-label="X">
														<i class="ph ph-x-logo" aria-hidden="true" />
													</span>
												)}
												<span>{source.name}</span>
											</span>
											{displayContentType(item) !== 'news' && (
												<span class="badge">{typeLabels[item.content_type]}</span>
											)}
										</div>
										<h3>
											{item.canonical_url ? (
												<a href={item.canonical_url} target="_blank" rel="noopener noreferrer">
													{title}
												</a>
											) : (
												title
											)}
										</h3>
										{summary && <p>{summary}</p>}
									</div>
								</article>
							);
						})}

						<a class="feed-more" href={latestHref}>
							{isEnglish ? `View all ${items.length} items →` : `查看全部 ${items.length} 条 →`}
						</a>
					</div>

					<aside class="side">
						<div class="side-card">
							<h3>{isEnglish ? 'TODAY AT A GLANCE' : '今日概览'}</h3>
							<div class="stat-row">
								<span>{isEnglish ? 'Total items' : '收录总数'}</span>
								<b>{items.length}</b>
							</div>
							{categoryRows.map(([category, count]) => (
								<Fragment>
									<div class="stat-row">
										<span>{categoryLabels[category] ?? category}</span>
										<b>{count}</b>
									</div>
									<div class="stat-row">
										<div class="bar">
											<i style={`width:${Math.round((count / items.length) * 100)}%`} />
										</div>
									</div>
								</Fragment>
							))}
						</div>

						{hotTopics.length > 0 && (
							<div class="side-card">
								<h3>{isEnglish ? 'TRENDING TOPICS' : '今日热点'}</h3>
								<div class="topic-chips">
									{hotTopics.map((topic) => (
										<a href={`/topics/${topic.slug}/`}>{taxonomyLabel(topic, locale)}</a>
									))}
								</div>
							</div>
						)}

						{previousDays.length > 0 && (
							<div class="side-card yesterday">
								<h3>{isEnglish ? 'PREVIOUS DAYS' : '往期'}</h3>
								{previousDays.map((day) => (
									<a class="y-link" href={day.href}>
										<span>
											<span class="y-date">{day.dateKey.slice(5)}</span>{' '}
											{formatDailyWeekday(day.date, locale, 'short')}
										</span>
										{day.count !== null && (
											<span class="y-count">
												{isEnglish ? `${day.count} items` : `${day.count} 条`}
											</span>
										)}
									</a>
								))}
								<a class="archive-link" href={archiveHref}>
									{isEnglish ? 'Full archive →' : '全部归档 →'}
								</a>
							</div>
						)}
					</aside>
				</div>
			</>
		) : (
			<header class="today-header">
				<div class="date-block">
					<h1>
						{monthDay}
						{weekdayLong && <span class="weekday">{weekdayLong}</span>}
					</h1>
					<p class="sub">
						<a href={latestHref}>{isEnglish ? 'Read the latest brief →' : '查看最新一期 →'}</a>
					</p>
				</div>
			</header>
		)
	}
</section>
