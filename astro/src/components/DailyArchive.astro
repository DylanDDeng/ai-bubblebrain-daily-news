---
import type { CollectionEntry } from 'astro:content';

import { dailyPermalink, formatDailyDate, type DailyLocale } from '../lib/daily';

interface Props {
	entries: CollectionEntry<'daily'>[];
	locale: DailyLocale;
}

const { entries, locale } = Astro.props;
const heading = locale === 'en' ? 'Daily Brief' : '资讯日报';
---

<section class="page-shell">
	<header class="page-heading">
		<h1>{heading}</h1>
	</header>

	<div class="archive-list">
		{
			entries.map((entry) => {
				const href = dailyPermalink(entry.id);
				if (!href) return null;

				return (
					<article class="archive-card">
						<time datetime={entry.data.date.toISOString()}>
							{formatDailyDate(entry.data.date, locale)}
						</time>
						<h2>
							<a href={href}>{entry.data.title}</a>
						</h2>
					</article>
				);
			})
		}
	</div>
</section>
