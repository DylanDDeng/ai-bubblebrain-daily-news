---
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

import { dailyDateFromKey, formatDailyWeekday, type DailyLocale } from '../lib/daily';
import {
	cleanTimelineSummary,
	formatDailyTime,
	formatTimelineTime,
	orderTimelineBatches,
	timelineDisplayText,
	type DailyContentType,
	type StructuredDailyReport,
} from '../lib/structuredDaily';
import { entitiesById, taxonomyLabel, topicsById } from '../lib/knowledge';

interface Props {
	report: StructuredDailyReport;
	locale: DailyLocale;
	newerHref?: string | null;
	olderHref?: string | null;
}

const { report, locale, newerHref = null, olderHref = null } = Astro.props;
const isEnglish = locale === 'en';

// Shared timeline assets are served unhashed from static/, so bust the
// browser cache with a build-time content hash query instead.
const staticAssetVersion = (assetPath: string): string => {
	try {
		const bytes = readFileSync(resolve(process.cwd(), '..', 'static', assetPath));
		return createHash('sha256').update(bytes).digest('hex').slice(0, 10);
	} catch {
		return 'local';
	}
};
const timelineCssHref = `/css/daily-timeline.css?v=${staticAssetVersion('css/daily-timeline.css')}`;
const timelineJsSrc = `/js/daily-timeline.js?v=${staticAssetVersion('js/daily-timeline.js')}`;
const itemById = new Map(report.items.map((item) => [item.id, item]));
const typeLabels: Record<'all' | DailyContentType, string> = isEnglish
	? { all: 'All', news: 'News', project: 'Projects', paper: 'Papers', socialMedia: 'Social' }
	: { all: '全部', news: '资讯', project: '项目', paper: '论文', socialMedia: '社交' };
const typeOrder: Array<'all' | DailyContentType> = [
	'all',
	'news',
	'project',
	'paper',
	'socialMedia',
];
const typeCounts = new Map<DailyContentType, number>();
for (const item of report.items) {
	typeCounts.set(item.content_type, (typeCounts.get(item.content_type) ?? 0) + 1);
}

const overview = cleanTimelineSummary(report.overview.text);
const orderedBatches = orderTimelineBatches(report.batches);
const reportDate = dailyDateFromKey(report.date);
const dateTitle = new Intl.DateTimeFormat(locale, {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
	timeZone: 'Asia/Shanghai',
}).format(reportDate);
const weekday = formatDailyWeekday(reportDate, locale);
const archiveHref = isEnglish ? '/en/daily/' : '/daily/';

const updateTimes = report.batches
	.filter((batch) => batch.status === 'completed' && batch.generated_at)
	.map((batch) => batch.generated_at!)
	.sort()
	.map((iso) => formatDailyTime(iso, locale));
const updatesStat = isEnglish
	? `${updateTimes.length} updates${updateTimes.length > 0 ? ` (${updateTimes.join(' / ')})` : ''}`
	: `${updateTimes.length} 次更新${updateTimes.length > 0 ? `（${updateTimes.join(' / ')}）` : ''}`;
const topicCount = new Set(report.items.flatMap((item) => item.topic_ids)).size;

const hrefDateKey = (href: string | null): string | null =>
	href?.match(/(\d{4}-\d{2}-\d{2})\/?$/)?.[1] ?? null;
const navDateLabel = (dateKey: string): string =>
	new Intl.DateTimeFormat(locale, {
		month: 'long',
		day: 'numeric',
		timeZone: 'Asia/Shanghai',
	}).format(dailyDateFromKey(dateKey));
const newerKey = hrefDateKey(newerHref);
const olderKey = hrefDateKey(olderHref);
---

<link rel="stylesheet" href={timelineCssHref} />

<article
	class="daily-timeline"
	data-daily-timeline
	data-report-date={report.date}
	data-expand-label={isEnglish ? 'Expand summary' : '展开摘要'}
	data-collapse-label={isEnglish ? 'Collapse summary' : '收起摘要'}
>
	<nav class="timeline-date-nav" aria-label={isEnglish ? 'Daily navigation' : '日报日期导航'}>
		{
			newerHref ? (
				<a class="nav-newer" href={newerHref}>
					← {newerKey ? navDateLabel(newerKey) : isEnglish ? 'Newer' : '较新'}
				</a>
			) : (
				<span class="disabled nav-newer" aria-hidden="true">
					← {isEnglish ? 'Newer' : '较新'}
				</span>
			)
		}
		<a class="back" href={archiveHref}>{isEnglish ? '← Back to archive' : '← 返回归档'}</a>
		{
			olderHref ? (
				<a class="nav-older" href={olderHref}>
					{olderKey ? navDateLabel(olderKey) : isEnglish ? 'Older' : '较早'} →
				</a>
			) : (
				<span class="disabled nav-older" aria-hidden="true">
					{isEnglish ? 'Older' : '较早'} →
				</span>
			)
		}
	</nav>

	<header class="day-header">
		<p class="kicker">{isEnglish ? 'DAILY BRIEF' : '资讯日报 · DAILY BRIEF'}</p>
		<h1>
			<time datetime={report.date}>{dateTitle}</time>
			<span class="weekday">{weekday}</span>
		</h1>
		{overview && <p class="overview">{overview}</p>}
		<div class="stats">
			<span>{isEnglish ? `${report.items.length} items` : `${report.items.length} 条收录`}</span>
			<span>{updatesStat}</span>
			<span>{isEnglish ? `${topicCount} topics` : `${topicCount} 个主题`}</span>
		</div>
	</header>

	<section
		class="toolbar timeline-toolbar"
		aria-label={isEnglish ? 'Timeline filters' : '时间轴筛选'}
	>
		<div class="filters" role="group" aria-label={isEnglish ? 'Content type' : '内容类型'}>
			{
				typeOrder.map((type) => (
					<button
						type="button"
						data-filter-type={type}
						aria-pressed={type === 'all' ? 'true' : 'false'}
					>
						{typeLabels[type]} {type === 'all' ? report.items.length : (typeCounts.get(type) ?? 0)}
					</button>
				))
			}
		</div>
		<form class="search" data-timeline-search role="search">
			<label class="sr-only" for={`timeline-search-${report.date}`}
				>{isEnglish ? 'Search this day' : '搜索当日'}</label
			>
			<input
				id={`timeline-search-${report.date}`}
				name="q"
				type="search"
				autocomplete="off"
				placeholder={isEnglish ? 'Search this day' : '搜索当日'}
			/>
			<button type="submit">{isEnglish ? 'Search' : '搜索'}</button>
		</form>
	</section>

	<div class="timeline-status" aria-live="polite">
		<span data-result-count>{report.items.length}</span>
		<span>{isEnglish ? 'items shown' : '条资讯'}</span>
	</div>
	<noscript>
		<p class="timeline-status">
			{
				isEnglish
					? 'Filters require JavaScript; all items remain visible.'
					: '筛选需要 JavaScript；当前已展示全部内容。'
			}
		</p>
	</noscript>

	<div class="batches">
		{
			orderedBatches.map((batch) => {
				// The producer stores each batch in ascending chronology for deterministic artifacts.
				// The reading UI keeps that source untouched while showing each batch's newest item first.
				const items = batch.item_ids
					.map((id) => itemById.get(id))
					.filter((item) => item !== undefined)
					.reverse();
				const batchLabel = cleanTimelineSummary(batch.label);
				const pending = batch.status !== 'completed';
				return (
					<section
						class={`batch${pending ? ' pending' : ''}`}
						data-timeline-batch={batch.id}
						data-batch-status={batch.status}
					>
						<div class="batch-heading">
							<h2>
								{pending ? `${batchLabel} · ${isEnglish ? 'scheduled' : '等待中'}` : batchLabel}
							</h2>
							{!pending && (
								<span class="batch-count">
									<span data-batch-count>{items.length}</span>
									{isEnglish ? ' items' : ' 条'}
								</span>
							)}
							<span class="batch-line" />
						</div>
						{pending ? (
							<p class="pending-note">
								{isEnglish
									? 'Items will appear here once this batch is published.'
									: '本批次发布后，条目会出现在这里。'}
							</p>
						) : (
							<span class="timeline-rail" aria-hidden="true" />
						)}
						{!pending &&
							items.map((item, index) => {
								const displayText = timelineDisplayText(item);
								const summary = displayText.summary;
								const rawSummary = cleanTimelineSummary(item.summary);
								const sourceName = cleanTimelineSummary(item.source.name) || item.source_type;
								const title =
									displayText.title || (isEnglish ? 'Open original source' : '查看原文');
								const topics = item.topic_ids
									.map((id) => topicsById.get(id))
									.filter((topic) => topic !== undefined);
								const entities = item.entity_ids
									.map((id) => entitiesById.get(id))
									.filter((entity) => entity !== undefined);
								const reason = item.reason ? cleanTimelineSummary(item.reason) : '';
								const searchText = [
									title,
									sourceName,
									rawSummary,
									item.category,
									...topics.flatMap((topic) => [taxonomyLabel(topic, locale), ...topic.aliases]),
									...entities.flatMap((entity) => [
										taxonomyLabel(entity, locale),
										...entity.aliases,
									]),
								]
									.join(' ')
									.toLocaleLowerCase(locale);
								return (
									<article
										id={`news-${item.id}`}
										class={`timeline-item item${item.featured ? ' featured' : ''}`}
										data-timeline-item
										data-item-id={item.id}
										data-content-type={item.content_type}
										data-search={searchText}
										style={`--timeline-index: ${Math.min(index, 10)}`}
									>
										<span class="dot" aria-hidden="true" />
										<div class="item-body">
											<div class="meta">
												<span class="src">{sourceName}</span>
												<span class="badge">{typeLabels[item.content_type]}</span>
												{item.featured && (
													<span class="badge featured-badge">
														{isEnglish ? 'Selected' : '精选'}
													</span>
												)}
												<time datetime={item.published_at ?? item.published_date ?? undefined}>
													{formatTimelineTime(item, locale, report.date)}
												</time>
											</div>
											<h3 title={title}>
												{item.canonical_url ? (
													<a href={item.canonical_url} target="_blank" rel="noopener noreferrer">
														{title} <span class="ext">↗</span>
													</a>
												) : (
													title
												)}
											</h3>
											{summary && <p class="timeline-summary">{summary}</p>}
											{topics.length > 0 && (
												<ul class="topics" aria-label={isEnglish ? 'Topics' : '主题'}>
													{topics.map((topic) => (
														<li>
															<a href={`/topics/${topic.slug}/`}>{taxonomyLabel(topic, locale)}</a>
														</li>
													))}
												</ul>
											)}
											{entities.length > 0 && (
												<ul class="topics" aria-label={isEnglish ? 'Entities' : '相关实体'}>
													{entities.map((entity) => (
														<li>
															<a href={`/entities/${entity.slug}/`}>
																{taxonomyLabel(entity, locale)}
															</a>
														</li>
													))}
												</ul>
											)}
											{reason && (
												<p class="timeline-reason">
													<span>{isEnglish ? 'Why it matters' : '推荐理由'}</span>
													{reason}
												</p>
											)}
										</div>
									</article>
								);
							})}
						{!pending && items.length === 0 && (
							<p class="batch-empty">
								{isEnglish ? 'No new items in this batch.' : '本批次没有新增资讯。'}
							</p>
						)}
					</section>
				);
			})
		}
	</div>
	<p class="timeline-no-results" data-no-results hidden>
		<span>{isEnglish ? 'No items match these filters.' : '没有符合当前条件的资讯。'}</span>
		<button type="button" data-clear-filters>{isEnglish ? 'Clear filters' : '清除筛选'}</button>
	</p>

	<footer class="page-foot">
		<a href={archiveHref}>{isEnglish ? '← Back to archive' : '← 返回归档'}</a>
		<a href="#discussion">{isEnglish ? 'Discussion and additions ↓' : '讨论与补充 ↓'}</a>
	</footer>
</article>

<script is:inline type="module" src={timelineJsSrc}></script>
