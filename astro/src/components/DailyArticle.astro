---
import { render, type CollectionEntry } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';
import DailyTimeline from './DailyTimeline.astro';
import Discussion from './Discussion.astro';
import { formatDailyDate, parseDailyEntryId, type DailyLocale } from '../lib/daily';
import { commentThreadId } from '../lib/comments/threadId';
import { sanitizeLegacyDailyHtml } from '../lib/legacyDailyHtml';
import { isDatabaseOwnedDailyDate, loadStructuredDailyReport } from '../lib/structuredDaily';

interface Props {
	entry: CollectionEntry<'daily'>;
	locale: DailyLocale;
	newerHref?: string | null;
	olderHref?: string | null;
	alternateHref?: string | null;
}

const { entry, locale, newerHref = null, olderHref = null, alternateHref = null } = Astro.props;
const { Content } = await render(entry);
const archiveHref = locale === 'en' ? '/en/daily/' : '/daily/';
const identity = parseDailyEntryId(entry.id);
const report =
	identity && isDatabaseOwnedDailyDate(identity.dateKey)
		? await loadStructuredDailyReport(identity.dateKey)
		: null;
const legacyHtml = entry.rendered?.html ? sanitizeLegacyDailyHtml(entry.rendered.html) : null;
const currentRoute = Astro.url.pathname;
const threadId = commentThreadId({
	route: currentRoute,
	locale,
	chineseAlternateRoute: locale === 'en' ? alternateHref : null,
});
---

<BaseLayout
	title={`${entry.data.title} · Bubble's Brain`}
	description={entry.data.description}
	lang={locale}
	alternateHref={alternateHref}
>
	{
		report ? (
			<DailyTimeline report={report} locale={locale} newerHref={newerHref} olderHref={olderHref} />
		) : (
			<article class="article-shell" data-legacy-daily>
				<header class="article-header">
					<p class="eyebrow">{locale === 'en' ? 'DAILY BRIEF' : '资讯日报'}</p>
					<h1>{entry.data.title}</h1>
					<p class="article-meta">
						<time datetime={entry.data.date.toISOString()}>
							{formatDailyDate(entry.data.date, locale)}
						</time>
					</p>
				</header>
				<div class="legacy-content">
					{legacyHtml === null ? <Content /> : <Fragment set:html={legacyHtml} />}
				</div>
				<p>
					<a href={archiveHref}>{locale === 'en' ? '← Back to archive' : '← 返回日报归档'}</a>
				</p>
			</article>
		)
	}
	<Discussion threadId={threadId} locale={locale} />
</BaseLayout>
