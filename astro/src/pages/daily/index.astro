---
import { getCollection } from 'astro:content';

import DailyArchive from '../../components/DailyArchive.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { filterDailyEntries } from '../../lib/daily';

const entries = filterDailyEntries(await getCollection('daily'), 'zh-CN');
---

<BaseLayout title="资讯日报 · Bubble's Brain" description="Bubble's Brain 资讯日报归档">
	<DailyArchive entries={entries} locale="zh-CN" />
</BaseLayout>
