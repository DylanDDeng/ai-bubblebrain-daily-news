---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="登录 · Bubble's Brain" description="登录后参与文章讨论" noindex>
	<section class="page-shell auth-page" data-login-page data-locale="zh-CN">
		<p class="page-kicker">COMMUNITY ACCESS</p>
		<h1>登录</h1>
		<p>使用 Google 登录后，可以在文章下提问、补充信息或反馈复现结果。</p>
		<button type="button" class="primary-action" data-login-google disabled>使用 Google 继续</button
		>
		<p class="auth-page-status" data-login-status role="status"></p>
		<noscript><p>登录需要启用 JavaScript。你仍可以返回首页继续阅读。</p></noscript>
	</section>
</BaseLayout>

<script>
	import '../../scripts/loginPage';
</script>
