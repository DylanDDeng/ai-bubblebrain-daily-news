---
import TaxonomyDetailPage from '../../components/TaxonomyDetailPage.astro';
import {
	knowledgeTaxonomy,
	taxonomyRoutes,
	topicsById,
	type TaxonomyRoute,
	type TopicRecord,
} from '../../lib/knowledge';
import { buildKnowledgeSearchIndex, type KnowledgeSearchItem } from '../../lib/searchIndex';
import '../../styles/knowledge.css';

interface Props {
	route: TaxonomyRoute<TopicRecord>;
	items: KnowledgeSearchItem[];
}

export async function getStaticPaths() {
	const index = await buildKnowledgeSearchIndex();
	return taxonomyRoutes(knowledgeTaxonomy.topics, topicsById).map((route) => ({
		params: { slug: route.slug },
		props: {
			route,
			items: route.redirect
				? []
				: index.items.filter((item) => item.topic_ids.includes(route.record.id)),
		},
	}));
}

const { route, items } = Astro.props;
if (route.redirect) return Astro.redirect(`/topics/${route.canonical.slug}/`, 301);
---

<TaxonomyDetailPage kind="topic" record={route.record} items={items} />
