{
	"name": "bubble-brain-astro",
	"private": true,
	"type": "module",
	"version": "0.0.1",
	"engines": {
		"node": "^22.17.0 || >=24.0.0"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build && node scripts/generate-redirects.mjs",
		"preview": "astro preview",
		"astro": "astro",
		"check": "astro check",
		"lint": "eslint .",
		"format": "prettier --write .",
