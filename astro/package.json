		"ajv": "^8.20.0",
		"ajv-formats": "^3.0.1",
		"eslint": "^9.39.5",
		"eslint-plugin-astro": "^1.7.0",
		"globals": "^17.7.0",
		"prettier": "^3.9.5",
		"prettier-plugin-astro": "^0.14.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.64.0",
		"vitest": "^3.2.7"
	}
